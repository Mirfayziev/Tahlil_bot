# Flask
FLASK_SECRET_KEY=change-this-super-secret-key
FLASK_ENV=production

# Database (Postgres tavsiya etiladi, lokal test uchun sqlite ham ishlaydi)
DATABASE_URL=postgresql://user:password@localhost:5432/service_platform
# DATABASE_URL=sqlite:///local.db

# Redis (bildirishnoma navbatlari / cache uchun, ixtiyoriy)
REDIS_URL=redis://localhost:6379/0

# Internal API token — botlar va veb-platforma orasidagi ishonchli aloqa uchun
INTERNAL_API_TOKEN=change-this-internal-token

# Telegram botlar
CUSTOMER_BOT_TOKEN=123456:customer-bot-token
EXECUTOR_BOT_TOKEN=123456:executor-bot-token
NOTIFY_BOT_TOKEN=123456:notify-bot-token

# Web platforma manzili (botlar shu manzilga so'rov yuboradi)
WEB_API_BASE_URL=http://localhost:5000/api

# AI integratsiya
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
AI_PROVIDER=anthropic
# AI_PROVIDER=openai
OPENAI_API_KEY=

# AI avtomatik yo'naltirish: dispetcher shu vaqt ichida javob bermasa, AI o'zi tegishli bo'limga yuboradi
AUTO_ASSIGN_ENABLED=true
AUTO_ASSIGN_AFTER_MINUTES=15

# Fayl saqlash (MinIO / S3 mos)
S3_ENDPOINT=
S3_BUCKET=service-platform-files
S3_ACCESS_KEY=
S3_SECRET_KEY=
UPLOAD_FOLDER=uploads

# --- Xavfsizlik (TZ v2, bo'lim 1) ---
# HTTPS ortida (Nginx/production) FORCE_HTTPS=true qiling
FORCE_HTTPS=false
PASSWORD_MIN_LENGTH=8
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- JWT (TZ v2, bo'lim 2: API / mobil ilova) ---
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=30

# --- Email (TZ v2, bo'lim 4/7) ---
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@service-platform.local
MAIL_ADMIN_RECIPIENTS=

# --- SMS (TZ v2, bo'lim 4) — mahalliy provayder (masalan Eskiz.uz) uchun tayyor joy
SMS_PROVIDER_URL=
SMS_API_KEY=

# --- Performance (TZ v2, bo'lim 5) ---
# Lokal/dev uchun default SimpleCache (Redis shart emas). Productionda (bir nechta
# gunicorn worker) CACHE_TYPE=RedisCache qiling — docker-compose.yml buni avtomatik qiladi.
CACHE_TYPE=SimpleCache
CACHE_REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TIMEOUT=30

# --- Docker Compose uchun Postgres ---
POSTGRES_DB=service_platform
POSTGRES_USER=service_platform
POSTGRES_PASSWORD=change-this-password
HTTP_PORT=80
